[init]
	defaultBranch = main
[core]
	editor = vim
[branch]
	sort = -committerdate
[diff]
	algorithm = histogram
	colorMoved = default
	renames = true
[merge]
	conflictStyle = zdiff3
[column]
	ui = auto
[fetch]
	prune = true
	pruneTags = true
[pull]
	ff = only
[push]
	autoSetupRemote = true
[rebase]
	autoStash = true
[rerere]
	enabled = true
	autoupdate = true
[help]
	autocorrect = prompt
[include]
	path = ~/.gitconfig.local

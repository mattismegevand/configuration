alias vim="nvim"

alias cp="cp -iv"
alias mv="mv -iv"
alias ln="ln -v"

alias ga="git add"
alias gc="git commit"
alias gca="git commit --amend"
alias gcane="git commit --amend --no-edit"
alias gco="git checkout"
alias gcob="git checkout -b"
alias gd="git diff"
alias gds="git diff --staged"
alias gdh="git diff HEAD"
alias gf="git fetch"
alias gl="git log"
alias glo="git log --oneline"
alias gp="git push"
alias gpu="git pull"
alias gs="git status"

alias radio="mpv 'https://www.youtube.com/watch?v=jfKfPfyJRdk' --no-video"
